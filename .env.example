# Токен Telegram-бота, который выдает @BotFather
BOT_TOKEN=

# URL подключения к Redis.
# Для локального запуска обычно: redis://localhost:6379/0
# В Docker Compose это значение переопределяется на redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# Telegram chat_id, куда бот отправляет уведомления администратору.
# Для личного чата это обычно ваш личный chat id.
ADMIN_CHAT_ID=

# Telegram user_id администратора, которому доступны /admin, /stats и /top3.
ADMIN_USER_ID=

# ID Google-таблицы.
# Это длинное значение в URL таблицы между /d/ и /edit.
GOOGLE_SPREADSHEET_ID=

# Путь к JSON-файлу сервисного аккаунта Google.
# Для локального запуска можно хранить файл в корне проекта как google_sa.json.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=google_sa.json

# Название листа внутри Google-таблицы.
GOOGLE_WORKSHEET_TITLE=Sheet1

# API-ключ Yandex Foundation Models.
LLM_API_KEY=

# URI модели Yandex LLM, например: gpt://<folder_id>/<model_name>
LLM_MODEL_URI=

# Endpoint Yandex LLM API.
LLM_API_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion

# Минимальная сумма баллов для уведомления о сильном кандидате.
HOT_CANDIDATE_THRESHOLD=70
